<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Interna Matutino</title>

  <style>
    body{
      margin:0;
      font-family:Arial;
      background:#f4f7f8;
      color:#003b3f;
      display:flex;
      justify-content:center;
      align-items:center;
      height:100vh;
    }

    .card{
      background:white;
      width:400px;
      padding:30px;
      border-radius:20px;
      box-shadow:0 10px 30px rgba(0,0,0,0.1);
    }

    h1{
      margin-top:0;
      color:#006465;
    }

    .status{
      margin-top:20px;
      padding:15px;
      border-radius:12px;
      background:#e7f5f5;
    }
  </style>
</head>
<body>

<div class="card">
  <h1>Interna Matutino</h1>

  <p>GitHub + Firebase conectado.</p>

  <div class="status" id="estado">
    Conectando...
  </div>
</div>

<script type="module">

import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.5/firebase-app.js";

const firebaseConfig = {
  apiKey: "PEGAR_APIKEY",
  authDomain: "internamatutino.firebaseapp.com",
  projectId: "internamatutino",
  storageBucket: "internamatutino.appspot.com",
  messagingSenderId: "PEGAR_ID",
  appId: "PEGAR_APPID"
};

const app = initializeApp(firebaseConfig);

document.getElementById("estado").innerHTML =
"Firebase conectado correctamente";

</script>

</body>
</html>
